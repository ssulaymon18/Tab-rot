{
  "manifest_version": 3,
  "name": "Tab Rot",
  "version": "1.0",
  "description": "Makes long-ignored tabs visibly rot over time by changing their icons.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}